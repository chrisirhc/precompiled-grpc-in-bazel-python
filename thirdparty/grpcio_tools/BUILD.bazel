load("@rules_python//python:defs.bzl", "py_binary", "py_test")

# Wrapper that filters out unsupported protoc flags for legacy protoc versions
py_binary(
    name = "main",
    srcs = ["main.py"],
    visibility = ["//visibility:public"],
    deps = [
        "@pypi//grpcio_tools",
    ],
)

py_test(
    name = "main_test",
    srcs = ["main_test.py"],
    deps = [
        "@pypi//grpcio_tools",
    ],
    data = [":main.py"],
)
